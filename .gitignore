# ============================================================================
# MNIST Digit Recognizer — .gitignore
# ============================================================================
# Strategy: track code, scripts, and folder structure.
# Never track raw data, large models, virtual envs, or system noise.
# ============================================================================

# ----------------------------------------------------------------------------
# Data
# ----------------------------------------------------------------------------
# MNIST is downloaded fresh on every machine via torchvision (~50 MB).
# Generated arrays / processed npz live here too — regenerated by the scripts.
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# ----------------------------------------------------------------------------
# Models
# ----------------------------------------------------------------------------
# Most checkpoints stay local. The final CNN weights for the Streamlit demo
# get an explicit whitelist below once we know the file size.
models/*
!models/.gitkeep
*.pt
*.pth
*.onnx
*.joblib
*.pkl
*.pickle
*.h5

# Allow the small final CNN that the deployed app needs
# (uncomment once Phase 5 finishes and we know the actual filename)
# !models/cnn_final.pt

# ----------------------------------------------------------------------------
# Plots (generated)
# ----------------------------------------------------------------------------
**/plots/*
!**/plots/.gitkeep

# ----------------------------------------------------------------------------
# Python
# ----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/

# Type-check / lint / test caches
.mypy_cache/
.pytest_cache/
.ruff_cache/

# Coverage
.coverage
htmlcov/

# ----------------------------------------------------------------------------
# Virtual environments
# ----------------------------------------------------------------------------
.venv/
venv/
env/
ENV/

# ----------------------------------------------------------------------------
# Jupyter
# ----------------------------------------------------------------------------
.ipynb_checkpoints/
*-checkpoint.ipynb

# ----------------------------------------------------------------------------
# IDE / editor
# ----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# ----------------------------------------------------------------------------
# OS
# ----------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
~$*

# ----------------------------------------------------------------------------
# Secrets / config
# ----------------------------------------------------------------------------
.env
.env.local
*.key
*.pem

# ----------------------------------------------------------------------------
# Streamlit / app runtime
# ----------------------------------------------------------------------------
.streamlit/secrets.toml

# ----------------------------------------------------------------------------
# Logs
# ----------------------------------------------------------------------------
*.log
logs/
runs/
lightning_logs/
